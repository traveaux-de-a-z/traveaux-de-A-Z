<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Site Travaux</title>
  <link rel="stylesheet" href="style.css">
</head>

<body>

<header class="header">
  <h1>Site Travaux</h1>
  <nav>
    <a href="#services">Services</a>
    <a href="#apropos">À propos</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section class="hero">
  <h2>Solutions industrielles & travaux</h2>
  <p>Achat, vente et mise en relation de matériel industriel</p>
  <a href="#contact" class="btn">Contactez-nous</a>
</section>

<section id="services" class="section">
  <h2>Services</h2>

  <div class="cards">
    <div class="card">
      <h3>Rachat matériel</h3>
      <p>Nous reprenons vos machines et équipements industriels.</p>
    </div>

    <div class="card">
      <h3>Mise en relation</h3>
      <p>Connexion avec des professionnels du secteur.</p>
    </div>

    <div class="card">
      <h3>Valorisation</h3>
      <p>Optimisation et revente du matériel.</p>
    </div>
  </div>
</section>

<section id="apropos" class="section">
  <h2>À propos</h2>
  <p>
    Spécialiste du secteur industriel, nous facilitons les échanges entre vendeurs et acheteurs.
  </p>
</section>

<section id="contact" class="section">
  <h2>Contact</h2>

  <form>
    <input type="text" placeholder="Nom" required>
    <input type="email" placeholder="Email" required>
    <textarea placeholder="Message" required></textarea>
    <button type="submit">Envoyer</button>
  </form>
</section>

<footer>
  <p>© 2026 Site Travaux - Tous droits réservés</p>
</footer>

<script src="script.js"></script>
</body>
</html>
